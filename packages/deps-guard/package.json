{
  "name": "deps-guard",
  "version": "0.0.2",
  "description": "Block outdated dependencies before they run your project.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renanzan/deps-guard.git"
  },
  "type": "module",
  "bin": {
    "deps-guard": "./bin/deps-guard.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "schemas"
  ],
  "scripts": {
    "test": "node --test __tests__/**/*.test.js",
    "lint": "eslint src test"
  },
  "keywords": [
    "deps",
    "dependencies",
    "outdated",
    "cli",
    "predev",
    "guard"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "@clack/prompts": "^0.7.0",
    "ora": "^8.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
